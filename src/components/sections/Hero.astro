---
import BtnLink from "../shared/BtnLink.astro";
import Container from "../shared/Container.astro";
import Paragraph from "../shared/Paragraph.astro";
import AnimatedHeroLogo from "../elements/AnimatedHeroLogo.astro";
import ContactChannelsModal from "../elements/ContactChannelsModal.astro";
---

<section id="hero" class="relative pt-32 lg:pt-36 overflow-hidden">
  <!-- Background Elements -->
  <div class="absolute top-0 left-0 w-full h-full overflow-hidden -z-10">
    <div class="absolute w-full lg:w-1/2 inset-y-0 lg:right-0">
      <span
        class="absolute -left-6 md:left-4 top-24 lg:top-28 w-24 h-24 rotate-90 skew-x-12 rounded-3xl bg-secondary blur-xl opacity-60 lg:opacity-95 lg:block hidden animate-float"
      ></span>
      <span
        class="absolute right-4 bottom-12 w-24 h-24 rounded-3xl bg-primary blur-xl opacity-80 animate-float delay-300"
      ></span>
    </div>
    <span
      class="w-4/12 lg:w-2/12 aspect-square bg-gradient-to-tr from-primary to-secondary absolute -top-5 lg:left-0 rounded-full skew-y-12 blur-2xl opacity-40 skew-x-12 rotate-90 animate-pulse-slow"
    ></span>

    <!-- Subtle Grid Pattern -->
    <div
      class="absolute inset-0 bg-[linear-gradient(to_right,#80808012_1px,transparent_1px),linear-gradient(to_bottom,#80808012_1px,transparent_1px)] bg-[size:24px_24px]"
    >
    </div>
  </div>

  <Container className={"flex flex-col gap-10 lg:flex-row lg:items-center lg:gap-10 xl:gap-16"}>
    <div
      class="relative mx-auto flex max-w-3xl flex-col items-center text-center lg:mx-0 lg:w-1/2 lg:max-w-none lg:flex-1 lg:items-start lg:py-7 xl:py-8 lg:text-left"
    >
      <h1
        class="max-w-[13ch] text-3xl/tight font-bold text-heading-1 opacity-0 animate-fade-in-up sm:text-4xl/tight md:max-w-[14ch] md:text-5xl/[1.05] xl:text-[3.45rem]/[1.02]"
      >
        Abastecimiento <span
          class="text-transparent bg-clip-text bg-gradient-to-br from-primary from-20% via-primary via-30% to-secondary"
          > Estratégico y Gestión Integral</span
        > en Salud.
      </h1>
      <Paragraph className="mt-6 max-w-[66ch] opacity-0 animate-fade-in-up delay-100 lg:mt-7">
        En Dynamic S.A. somos su socio estratégico. Conectamos la mejor tecnología médica con quienes más la necesitan, abasteciendo de manera integral al sector salud, tanto público como privado. Garantizamos rapidez, seguridad y compromiso en la provisión de insumos de alta complejidad. A su vez, administramos padrones de pacientes crónicos y obras sociales, asegurando la entrega directa y la continuidad ininterrumpida de los tratamientos en todo el país.
      </Paragraph>
      <div
        class="mt-8 flex w-full max-w-md opacity-0 animate-fade-in-up delay-200 lg:mx-0 lg:mt-9"
      >
        <div class="flex sm:flex-row flex-col gap-5 w-full">
          <div class="flex flex-col sm:flex-row gap-4 w-full">
            <ContactChannelsModal
              className="flex justify-center w-full sm:w-max shadow-lg shadow-primary/30 hover:shadow-xl hover:shadow-primary/40 transition-shadow"
              buttonText="Contáctenos"
              modalTitle="Contacte al área correcta"
              modalSubtitle="Seleccione sucursal y área."
              branches={[
                {
                  branch: "Sucursal Córdoba",
                  options: [
                    {
                      area: "Ostomía",
                      phoneLabel: "+54 9 3512 67-0600",
                      whatsappHref: "#",
                    },
                  ],
                },
                {
                  branch: "Sucursal Tucumán",
                  options: [
                    {
                      area: "Nutrición",
                      phoneLabel: "+54 9 3816 64-0038",
                      whatsappHref: "#",
                    },
                  ],
                },
              ]}
            />

            <BtnLink
              text="Nuestros Servicios"
              href="#services"
              className="flex justify-center w-full sm:w-max text-primary border-primary hover:bg-primary/5"
              variant="outline"
            />
          </div>
        </div>
      </div>
    </div>

    <div
      class="relative mx-auto hidden max-w-3xl flex-1 opacity-0 animate-fade-in-up delay-300 md:flex lg:mx-0 lg:h-auto lg:w-1/2 lg:max-w-none"
    >
      <AnimatedHeroLogo />
    </div>
  </Container>
</section>
