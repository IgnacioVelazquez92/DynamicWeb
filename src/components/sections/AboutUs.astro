---
import Info from "../cards/Info.astro";
import Container from "../shared/Container.astro";
import Paragraph from "../shared/Paragraph.astro";
import Title from "../shared/Title.astro";

const baseUrl = import.meta.env.BASE_URL;
---

<section id="about-us" class="relative overflow-hidden">
  <Container>
    <div class="grid gap-4 lg:gap-5">
      <div
        class="grid items-center gap-6 px-1 pt-1 pb-1 lg:grid-cols-[minmax(0,1.45fr)_minmax(18rem,0.9fr)] lg:px-2 xl:gap-8"
      >
        <div class="order-2 min-w-0 lg:order-1">
          <Title>
            <span class="mt-4 block">Quiénes Somos</span>
          </Title>
          <Paragraph className="mt-6 max-w-3xl text-balance">
            Somos una empresa integral de salud dedicada a conectar la
            tecnología médica de excelencia con quienes más la necesitan. Nos
            especializamos en el abastecimiento estratégico de medicamentos e insumos
            médicos de alta complejidad para el sector público y privado, y en la administración
            de terapias para pacientes crónicos.
          </Paragraph>
          <Paragraph className="mt-4 max-w-3xl text-balance">
            Desde nuestros inicios, nos enfocamos en garantizar que cada
            producto llegue en el momento exacto, cumpliendo con los más
            estrictos estándares de calidad, seguridad y trazabilidad en toda la
            cadena de valor, con operaciones en Córdoba y Tucumán y alcance comercial en todo el país.
          </Paragraph>
        </div>

        <div
          class="order-1 mx-auto flex w-full max-w-sm justify-center lg:order-2 lg:max-w-none"
        >
          <div class="relative h-80 w-full sm:h-96 lg:h-[28rem] xl:h-[30rem]">
            <div
              class="absolute top-1/2 -left-5 h-16 w-16 -translate-y-1/2 rotate-45 bg-gradient-to-br from-primary to-orange-400 p-1 opacity-50 blur-3xl md:-left-10"
            >
            </div>
            <div
              class="absolute -top-4 right-4 h-20 w-20 rounded-full bg-gradient-to-br from-primary to-orange-400 p-1 opacity-60 blur-3xl md:-top-8"
            >
            </div>
            <div
              class="absolute inset-x-6 bottom-4 top-10 rounded-[2rem] bg-linear-to-b from-white/70 via-white/20 to-transparent shadow-inner shadow-white/30 ring-1 ring-white/40 dark:from-gray-900/50 dark:via-gray-900/10 dark:ring-white/10"
            >
            </div>
            <span
              class="absolute bottom-2 left-0 aspect-[16/5] w-full -skew-x-12 rounded-full bg-gradient-to-tr from-primary to-secondary opacity-40 blur-2xl"
            ></span>
            <img
              src={`${baseUrl}logos/Dynamic_svg.svg`}
              alt="Logo de Dynamic SA"
              width="1240"
              height="420"
              loading="lazy"
              class="absolute left-1/2 top-1/2 block w-[82%] max-w-[22rem] -translate-x-1/2 -translate-y-1/2 dark:hidden"
            />
            <img
              src={`${baseUrl}logos/Dynamic_svg_dark.svg`}
              alt="Logo de Dynamic SA"
              width="1240"
              height="420"
              loading="lazy"
              class="absolute left-1/2 top-1/2 hidden w-[82%] max-w-[22rem] -translate-x-1/2 -translate-y-1/2 dark:block"
            />
          </div>
        </div>
      </div>

      <div class="grid gap-4 sm:gap-5 lg:grid-cols-2 lg:gap-6">
        <Info
          title="Misión"
          description="Garantizar el acceso ininterrumpido a tecnología médica y tratamientos de alta complejidad, brindando soluciones de abastecimiento eficientes, seguras y transparentes para instituciones, junto con un acompañamiento empático y proactivo para cada paciente."
        >
          <span slot="icon">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="30"
              fill="none"
              viewBox="0 0 24 24"
              stroke-width="1.5"
              stroke="currentColor"
              class="h-4 w-4 sm:h-5 sm:w-5"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z"
              ></path>
            </svg>
          </span>
        </Info>

        <Info
          title="Visión"
          description="Ser el socio estratégico y prestador integral de salud más confiable a nivel nacional, reconocidos por nuestra innovación operativa, nuestra capacidad logística y nuestro compromiso inquebrantable con la calidad de vida de las personas."
        >
          <span slot="icon">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="30"
              fill="none"
              viewBox="0 0 24 24"
              stroke-width="1.5"
              stroke="currentColor"
              class="h-4 w-4 sm:h-5 sm:w-5"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z"
              ></path>
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"
              ></path>
            </svg>
          </span>
        </Info>
      </div>
    </div>
  </Container>
</section>
