---
import Service from "../cards/Service.astro";
import Container from "../shared/Container.astro";
import Paragraph from "../shared/Paragraph.astro";
import Title from "../shared/Title.astro";
---

<section id="services">
  <Container className="space-y-10 md:sapce-y-12">
    <div class="text-center max-w-3xl mx-auto space-y-4">
      <Title> Nuestros Servicios </Title>
      <Paragraph>
        Brindamos soluciones integrales de logística y distribución para el sector farmacéutico.
      </Paragraph>
    </div>
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
      <Service
        title="Logística Farmacéutica"
        description="Distribución eficiente y segura a farmacias y centros de salud en todo el país."
        icon="/images/Logistica.png"
        iconAlt="Logística farmacéutica"
      />
      <Service
        title="Distribuidor de insumos médicos y medicamentos"
        description="Abastecimiento confiable de insumos médicos y medicamentos para instituciones de salud y farmacias."
        icon="/images/medicamentos.png"
        iconAlt="Insumos médicos y medicamentos"
      />
      <Service
        title="Atención Personalizada"
        description="Equipo comercial dedicado para asistir a nuestros clientes en cada requerimiento."
        icon="/images/ventas.png"
        iconAlt="Atención personalizada"
      />
    </div>
  </Container>
</section>
