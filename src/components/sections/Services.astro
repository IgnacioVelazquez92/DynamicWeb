---
import Service from "../cards/Service.astro";
import Container from "../shared/Container.astro";
import Paragraph from "../shared/Paragraph.astro";
import Title from "../shared/Title.astro";

const baseUrl = import.meta.env.BASE_URL;
---

<section id="services">
  <Container className="space-y-10 md:sapce-y-12">
    <div class="text-center max-w-3xl mx-auto space-y-4">
      <Title> Nuestros Servicios </Title>
      <Paragraph>
        Brindamos abastecimiento estratégico de insumos médicos de alta complejidad y gestión integral de tratamientos para instituciones, financiadores y pacientes.
      </Paragraph>
    </div>
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
      <Service
        title="Provisión Institucional"
        description="Abastecimiento integral a clínicas, hospitales y sector público. Garantizamos stock permanente, trazabilidad y cumplimiento estricto en la entrega de insumos médicos de alta complejidad."
        icon={`${baseUrl}images/Logistica.png`}
        iconAlt="Provisión Institucional"
      />
      <Service
        title="Gestión de Padrones"
        description="Administración y auditoría de pacientes crónicos para obras sociales. Realizamos contacto proactivo, validación de recetas y seguimiento para asegurar la continuidad de cada tratamiento."
        icon={`${baseUrl}images/medicamentos.png`}
        iconAlt="Gestión de Padrones"
      />
      <Service
        title="Atención al Paciente"
        description="Llegamos directo al domicilio del afiliado. Nuestro equipo especializado brinda asesoramiento y entrega rápida de insumos de ostomía, sondaje y nutrición, mejorando su calidad de vida."
        icon={`${baseUrl}images/ventas.png`}
        iconAlt="Atención al Paciente"
      />
    </div>
  </Container>
</section>
