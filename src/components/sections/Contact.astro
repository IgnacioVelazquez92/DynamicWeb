---
import Container from "../shared/Container.astro";
import Paragraph from "../shared/Paragraph.astro";
import Title from "../shared/Title.astro";
---

<section id="contact" class="pb-20">
  <Container>
    <div class="max-w-2xl mx-auto text-center mb-10 md:mb-12">
      <Title> Contáctenos </Title>
      <Paragraph>
        Estamos a su disposición para consultas comerciales y administrativas.
      </Paragraph>
    </div>

    <div class="grid md:grid-cols-2 gap-10 mx-auto max-w-4xl">
      <!-- Contact Info -->
      <div class="space-y-6">
        <div>
          <h3 class="text-xl font-semibold text-heading-1 mb-2">Dirección</h3>
          <p class="text-heading-3">
            Calle Falsa 123, Ciudad Autónoma de Buenos Aires, Argentina
          </p>
        </div>

        <div>
          <h3 class="text-xl font-semibold text-heading-1 mb-2">Contacto</h3>
          <p class="text-heading-3">
            <span class="font-semibold">Teléfono:</span> +54 11 1234-5678<br />
            <span class="font-semibold">Email:</span> info@dynamic-sa.com.ar
          </p>
        </div>

        <div>
          <h3 class="text-xl font-semibold text-heading-1 mb-2">
            Horario de Atención
          </h3>
          <p class="text-heading-3">Lunes a Viernes: 8:00 - 17:00 hs</p>
        </div>
      </div>

      <!-- Map Placeholder -->
      <div
        class="bg-box-bg border border-box-border rounded-3xl p-4 shadow-lg shadow-box-shadow min-h-[300px] flex items-center justify-center relative overflow-hidden"
      >
        <iframe
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d13136.066850016401!2d-58.38157039999999!3d-34.6037389!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x4aa9f0a6da5edb%3A0x11bead4e234e558b!2sObelisco!5e0!3m2!1ses-419!2sar!4v1695684697966!5m2!1ses-419!2sar"
          width="100%"
          height="100%"
          style="border:0; position: absolute; inset: 0;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
        >
        </iframe>
      </div>
    </div>
  </Container>
</section>
