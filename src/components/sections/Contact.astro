---
import Container from "../shared/Container.astro";
import Paragraph from "../shared/Paragraph.astro";
import Title from "../shared/Title.astro";
---

<section id="contact" class="relative py-20 lg:py-28 overflow-hidden">
  <!-- Background Elements -->
  <div class="absolute top-0 left-0 w-full h-full overflow-hidden -z-10">
    <span
      class="absolute -left-20 top-10 w-64 h-64 rounded-full bg-gradient-to-tr from-primary/20 to-secondary/20 blur-3xl opacity-60 animate-pulse-slow"
    ></span>
    <span
      class="absolute -right-20 bottom-10 w-72 h-72 rounded-full bg-gradient-to-tl from-secondary/20 to-primary/20 blur-3xl opacity-50 animate-pulse-slow delay-1000"
    ></span>
    <span
      class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 w-96 h-96 rounded-full bg-gradient-to-br from-secondary/10 to-transparent blur-3xl opacity-40 animate-pulse-slow delay-500"
    ></span>
    
    <!-- Subtle Grid Pattern -->
    <div
      class="absolute inset-0 bg-[linear-gradient(to_right,#80808012_1px,transparent_1px),linear-gradient(to_bottom,#80808012_1px,transparent_1px)] bg-[size:24px_24px]"
    >
    </div>
  </div>

  <Container className="relative z-10">
    <div class="max-w-2xl mx-auto text-center mb-16 md:mb-20">
      <Title> Contáctenos </Title>
      <Paragraph>
        Estamos a su disposición para consultas comerciales y administrativas.
      </Paragraph>
    </div>

    <!-- Contact Info Section with Maps -->
    <div class="grid md:grid-cols-2 gap-8 mx-auto max-w-4xl">
      <!-- Contact Info -->
      <div class="space-y-4">
        <div>
          <h3 class="text-lg font-semibold text-heading-1 mb-3">Direcciones</h3>
          <div class="space-y-2 text-heading-3 text-sm">
            <p>
              <span class="font-semibold">Tucumán:</span><br />
              Santiago del Estero 1616<br />
              San Miguel de Tucumán, Argentina
            </p>
            <p class="pt-2">
              <span class="font-semibold">Córdoba:</span><br />
              Spilimbergo 6392<br />
              Córdoba, Argentina
            </p>
          </div>
        </div>

        <div>
          <h3 class="text-lg font-semibold text-heading-1 mb-3">Contacto</h3>
          <p class="text-heading-3 text-sm">
            <span class="font-semibold">Teléfono:</span> +54 9 3512 67-0600<br />
            <span class="font-semibold">Email:</span> comercial@dynamicsa.com.ar
          </p>
        </div>

        <div>
          <h3 class="text-lg font-semibold text-heading-1 mb-3">
            Horario de Atención
          </h3>
          <p class="text-heading-3 text-sm">Lunes a Viernes: 8:00 - 17:00 hs</p>
        </div>
      </div>

      <!-- Maps Section -->
      <div class="space-y-3 flex flex-col">
        <!-- Map Tucumán -->
        <div class="flex flex-col flex-1">
          <h3 class="text-xs font-semibold text-heading-1 mb-2">Tucumán</h3>
          <div
            class="bg-box-bg border border-box-border rounded-lg p-2 shadow-lg shadow-box-shadow flex-1 relative overflow-hidden h-[140px]"
          >
            <iframe
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3560.6097577275386!2d-65.22009663797758!3d-26.82055173209453!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x94225c41616bd0a1%3A0xfb9f135ff1a7a3f3!2sSantiago%20del%20Estero%201616%2C%20T4000%20San%20Miguel%20de%20Tucum%C3%A1n%2C%20Tucum%C3%A1n!5e0!3m2!1ses!2sar!4v1770856781622!5m2!1ses!2sar"
              width="100%"
              height="100%"
              style="border:0; position: absolute; inset: 0; border-radius: 6px;"
              allowfullscreen=""
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
            >
            </iframe>
          </div>
        </div>

        <!-- Map Córdoba -->
        <div class="flex flex-col flex-1">
          <h3 class="text-xs font-semibold text-heading-1 mb-2">Córdoba</h3>
          <div
            class="bg-box-bg border border-box-border rounded-lg p-2 shadow-lg shadow-box-shadow flex-1 relative overflow-hidden h-[140px]"
          >
            <iframe
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3407.6257921809465!2d-64.2255962116166!3d-31.34170608621965!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x9432995bfb48f1c9%3A0x40af1794d6a98047!2sLino%20Eneas%20Spilimbergo%206392%2C%20X5003DEV%20C%C3%B3rdoba!5e0!3m2!1ses!2sar!4v1770856916523!5m2!1ses!2sar"
              width="100%"
              height="100%"
              style="border:0; position: absolute; inset: 0; border-radius: 6px;"
              allowfullscreen=""
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
            >
            </iframe>
          </div>
        </div>
      </div>
    </div>


  </Container>
</section>
