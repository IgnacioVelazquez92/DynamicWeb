---
import GroupFooterNav from "../blocks/GroupFooterNav.astro";
import Container from "../shared/Container.astro";
import FooterNav from "../shared/FooterNav.astro";
import Paragraph from "../shared/Paragraph.astro";

const baseUrl = import.meta.env.BASE_URL;
---

<div class="mt-16"></div>
<div class="mt-16"></div>
<footer
  class="relative bg-gradient-to-tr from-gray-100 to-gray-200 dark:from-gray-900 dark:to-transparent pt-28 rounded-t-3xl"
>
  <div class="absolute right-0 top-0 h-full w-full flex justify-end">
    <div class="w-28 h-28 overflow-auto flex rounded-xl relative blur-2xl">
      <span
        class="absolute w-16 h-16 -top-1 -right-1 bg-secondary rounded-md rotate-45"
      ></span>
      <span
        class="absolute w-16 h-16 -bottom-1 -right-1 bg-[#FCDC58] rounded-md rotate-45"
      ></span>
      <span
        class="absolute w-16 h-16 -bottom-1 -left-1 bg-primary rounded-md rotate-45"
      ></span>
    </div>
  </div>

  <div class="absolute left-0 bottom-0 h-full w-full flex items-end">
    <div class="w-28 h-28 overflow-auto flex rounded-xl relative blur-2xl">
      <span
        class="absolute w-16 h-16 -top-1 -right-1 bg-secondary rounded-md rotate-45"
      ></span>
      <span
        class="absolute w-16 h-16 -bottom-1 -right-1 bg-[#FCDC58] rounded-md rotate-45"
      ></span>
      <span
        class="absolute w-16 h-16 -bottom-1 -left-1 bg-primary rounded-md rotate-45"
      ></span>
    </div>
  </div>
  <Container className="pb-8 relative overflow-auto">
    <span
      class="absolute top-1/2 left-1/2 -translate-y-1/2 -translate-x-1/2 blur-2xl opacity-20 w-24 h-16 sm:w-48 sm:h-36 rounded-full rotate-12 skew-x-6 bg-primary"
    ></span>
    <div
      class="grid grid-cols-2 lg:grid-cols-3 lg:items-stretch gap-8 relative"
    >
      <div class="col-span-2 lg:col-span-1 h-auto flex flex-col">
        <div class="h-full">
          <a href={baseUrl} class="relative flex items-center gap-3">
            <img
              src={`${baseUrl}logos/Dynamic_svg.svg`}
              alt="Dynamic SA Logo"
              class="h-10 w-auto dark:hidden"
            />
            <img
              src={`${baseUrl}logos/Dynamic_svg_dark.svg`}
              alt="Dynamic SA Logo"
              class="hidden h-10 w-auto dark:block"
            />
          </a>
          <Paragraph className={"mt-8"}>
            Dynamic SA. Excelencia en distribución farmacéutica. Conectando
            salud y bienestar en todo el país.
          </Paragraph>
        </div>

        <!-- social links -->
        <div class="min-h-max flex items-center gap-4 text-heading-3 mt-8">
          <!-- Social icons functionality to be added/updated if specific links provided -->
        </div>
      </div>

      <GroupFooterNav>
        <FooterNav
          title={"Empresa"}
          navItems={[
            { itemText: "Inicio", itemLink: baseUrl },
            { itemText: "Quiénes Somos", itemLink: "#about-us" },
            { itemText: "Servicios", itemLink: "#services" },
            { itemText: "Contacto", itemLink: "#contact" },
          ]}
        />
        <FooterNav
          title={"Servicios"}
          navItems={[
            { itemText: "Logística", itemLink: "#services" },
            { itemText: "Distribución", itemLink: "#services" },
            { itemText: "Cadena de Frío", itemLink: "#services" },
          ]}
        />
      </GroupFooterNav>

      <GroupFooterNav>
        <div class="flex flex-col gap-4">
          <h3 class="text-heading-1 font-semibold text-lg">Contacto</h3>
          <p class="text-heading-3">comercial@dynamicsa.com.ar</p>
          <p class="text-heading-3">+54 9 3512 67-0600</p>
        </div>
      </GroupFooterNav>
    </div>
  </Container>
  <div class="bg-gradient-to-tl from-box-bg py-2 relative">
    <Container>
      <div
        class="flex justify-between items-center gap-6 md:text-lg text-heading-3"
      >
        <div>
          &copy; <span id="year"></span> Dynamic SA. Todos los derechos reservados.
        </div>
      </div>
    </Container>
  </div>
</footer>

