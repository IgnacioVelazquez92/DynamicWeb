---
import { readFile } from "node:fs/promises";
import { join } from "node:path";

const logoPath = join(process.cwd(), "public", "logos", "Dynamic_svg.svg");
const logoSvg = await readFile(logoPath, "utf8");
const logoDarkPath = join(process.cwd(), "public", "logos", "Dynamic_svg_dark.svg");
const logoDarkSvg = await readFile(logoDarkPath, "utf8");
---

<div class="hero-logo-stage" aria-label="Dynamic">
  <div class="hero-logo-variant dark:hidden" data-hero-logo tabindex="0" aria-label="Dynamic logo claro">
    <div class="hero-logo-svg" set:html={logoSvg}></div>
  </div>
  <div class="hero-logo-variant hidden dark:block" data-hero-logo tabindex="0" aria-label="Dynamic logo oscuro">
    <div class="hero-logo-svg" set:html={logoDarkSvg}></div>
  </div>
</div>

<style>
  .hero-logo-stage {
    width: 100%;
    max-width: 48rem;
    margin-inline: auto;
  }

  .hero-logo-svg :global(svg) {
    width: 100%;
    height: auto;
    display: block;
    overflow: visible;
  }

  .hero-logo-svg :global(#mark),
  .hero-logo-svg :global(.letter) {
    transform-box: fill-box;
    backface-visibility: hidden;
    will-change: transform, opacity, fill;
  }
</style>

<script>
  import { gsap } from "gsap";

  function initHeroLogoAnimation() {
    const logoBlocks = document.querySelectorAll<HTMLElement>("[data-hero-logo]");
    if (!logoBlocks.length) return;

    logoBlocks.forEach((logoBlock) => {
      if (logoBlock.dataset.gsapReady === "true") return;

      const svg = logoBlock.querySelector<SVGSVGElement>("svg");
      if (!svg) return;

      const paths = Array.from(
        svg.querySelectorAll<SVGGraphicsElement>(
          "path, polygon, rect, circle, ellipse, line, polyline"
        )
      );
      if (!paths.length) return;

      const mark = paths.find((node) => {
        const styleAttr = node.getAttribute("style") ?? "";
        const fillAttr = (node.getAttribute("fill") ?? "").toLowerCase();
        return /fill:\s*#4dc083/i.test(styleAttr) || fillAttr === "#4dc083";
      });
      if (!mark) return;

      const letters = paths
        .filter((node) => node !== mark)
        .sort((a, b) => a.getBBox().x - b.getBBox().x);

      const getFillColor = (node: SVGGraphicsElement) => {
        const styleAttr = node.getAttribute("style") ?? "";
        const styleMatch = styleAttr.match(/fill:\s*([^;]+)/i);
        const fillAttr = node.getAttribute("fill");
        return (styleMatch?.[1] ?? fillAttr ?? "#4f4c4d").trim().toLowerCase();
      };

      const baseLetterFill = getFillColor(letters[0] ?? mark);
      const pulseLetterFill = baseLetterFill === "#c6c8cc" ? "#e2e4e8" : "#767273";

      mark.id = "mark";
      letters.forEach((node, index) => {
        node.classList.add("letter", `letter-${index + 1}`);
      });

      logoBlock.dataset.gsapReady = "true";
      const media = window.matchMedia("(prefers-reduced-motion: reduce)");

      let loopTimeline: gsap.core.Timeline | null = null;
      let loopDelay: gsap.core.Tween | null = null;
      let isVisible = true;

      const clearLoop = () => {
        loopTimeline?.kill();
        loopDelay?.kill();
        loopTimeline = null;
        loopDelay = null;
      };

      const playLoop = () => {
        if (!isVisible || media.matches) return;
        clearLoop();

        loopTimeline = gsap.timeline({
          defaults: { overwrite: "auto" },
          onComplete: () => {
            loopDelay = gsap.delayedCall(5.8, playLoop);
          },
        });

        // Micro-gesto de la D
        loopTimeline
          .to(
            mark,
            {
              rotation: -0.8,
              x: 1,
              duration: 0.24,
              ease: "power2.out",
              transformOrigin: "left center",
              transformBox: "fill-box",
            },
            0
          )
          .to(
            mark,
            {
              rotation: 0,
              x: 0,
              duration: 0.42,
              ease: "sine.out",
            },
            0.24
          );

        // Brillo por color, barrido izquierda->derecha
        loopTimeline
          .to(
            mark,
            {
              fill: "#62d399",
              duration: 0.22,
              ease: "sine.out",
            },
            0.12
          )
          .to(
            mark,
            {
              fill: "#4dc083",
              duration: 0.45,
              ease: "sine.inOut",
            },
            0.36
          )
          .to(
            letters,
            {
              fill: pulseLetterFill,
              opacity: 0.88,
              y: -1.6,
              duration: 0.24,
              ease: "sine.out",
              stagger: { each: 0.03, from: "start" },
            },
            0.18
          )
          .to(
            letters,
            {
              fill: baseLetterFill,
              opacity: 1,
              y: 0,
              duration: 0.45,
              ease: "sine.inOut",
              stagger: { each: 0.03, from: "start" },
            },
            0.42
          );
      };

      const intro = () => {
        clearLoop();
        gsap.killTweensOf([mark, ...letters]);

        gsap.set(mark, {
          opacity: 0,
          y: 8,
          x: 0,
          scaleX: 0,
          rotation: 0,
          fill: "#4dc083",
          transformOrigin: "left center",
          transformBox: "fill-box",
          force3D: true,
        });

        gsap.set(letters, {
          opacity: 0,
          y: 8,
          skewX: 2,
          fill: baseLetterFill,
          transformOrigin: "50% 50%",
          transformBox: "fill-box",
          force3D: true,
        });

        if (media.matches) {
          gsap.to([mark, ...letters], {
            opacity: 1,
            y: 0,
            skewX: 0,
            scaleX: 1,
            duration: 0.2,
            ease: "none",
            stagger: 0.01,
          });
          logoBlock.dataset.introDone = "true";
          return;
        }

        const timeline = gsap.timeline({ defaults: { ease: "power3.out" } });

        timeline.to(mark, {
          opacity: 1,
          y: 0,
          scaleX: 1,
          duration: 0.42,
          ease: "power2.out",
        });

        timeline.to(
          letters,
          {
            opacity: 1,
            y: 0,
            skewX: 0,
            duration: 0.46,
            stagger: 0.045,
          },
          0.24
        );

        timeline.call(() => {
          logoBlock.dataset.introDone = "true";
          playLoop();
        }, [], ">+0.45");
      };

      const microHover = () => {
        if (media.matches) return;
        gsap
          .timeline({ defaults: { duration: 0.18, ease: "power2.out" } })
          .to(mark, { x: 2, overwrite: "auto" })
          .to(mark, { x: 0, overwrite: "auto" }, ">0.02");
      };

      const observer = new IntersectionObserver(
        (entries) => {
          const entry = entries[0];
          isVisible = Boolean(entry?.isIntersecting);

          if (!isVisible) {
            clearLoop();
            gsap.set(mark, { scaleX: 1, x: 0, rotation: 0, fill: "#4dc083" });
            gsap.set(letters, { opacity: 1, y: 0, fill: baseLetterFill });
            return;
          }

          if (!media.matches && logoBlock.dataset.introDone === "true") {
            playLoop();
          }
        },
        { threshold: 0.05, rootMargin: "0px 0px -5% 0px" }
      );

      observer.observe(logoBlock);

      logoBlock.addEventListener("mouseenter", microHover);
      logoBlock.addEventListener("focusin", microHover);
      media.addEventListener("change", intro);

      intro();
    });
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initHeroLogoAnimation, {
      once: true,
    });
  } else {
    initHeroLogoAnimation();
  }

  document.addEventListener("astro:page-load", initHeroLogoAnimation);
</script>
