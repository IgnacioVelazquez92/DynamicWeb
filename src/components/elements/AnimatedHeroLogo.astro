---
import { readFile } from "node:fs/promises";
import { join } from "node:path";

const logoPath = join(process.cwd(), "public", "logos", "Dynamic_svg.svg");
const logoSvg = await readFile(logoPath, "utf8");
const logoDarkPath = join(process.cwd(), "public", "logos", "Dynamic_svg_dark.svg");
const logoDarkSvg = await readFile(logoDarkPath, "utf8");
---

<div class="hero-logo-stage" aria-label="Dynamic">
  <div class="hero-logo-variant logo-trigger-area dark:hidden" data-hero-logo tabindex="0" aria-label="Dynamic logo claro">
    <div class="hero-logo-svg" set:html={logoSvg}></div>
  </div>
  <div class="hero-logo-variant logo-trigger-area hidden dark:block" data-hero-logo tabindex="0" aria-label="Dynamic logo oscuro">
    <div class="hero-logo-svg" set:html={logoDarkSvg}></div>
  </div>
</div>

<style>
  @property --hover-scale {
    syntax: "<number>";
    inherits: false;
    initial-value: 0;
  }

  @property --hover-offset-y {
    syntax: "<length>";
    inherits: false;
    initial-value: 0px;
  }

  .hero-logo-stage {
    width: 100%;
    max-width: 48rem;
    margin-inline: auto;
  }

  .hero-logo-svg :global(svg) {
    width: 100%;
    height: auto;
    display: block;
    overflow: visible;
  }

  .hero-logo-variant {
    --stagger-delay: 0.04s;
  }

  .logo-trigger-area {
    background-color: rgba(255, 255, 255, 0.001);
    cursor: pointer;
  }

  .hero-logo-svg :global(.dynamic-logo) {
    animation: float 6s ease-in-out infinite;
    overflow: visible;
    will-change: transform;
    animation-play-state: paused;
    transition: filter 0.35s ease;
  }

  .hero-logo-variant[data-intro-done="true"] .hero-logo-svg :global(.dynamic-logo) {
    animation-play-state: running;
  }

  .hero-logo-svg :global(.anim-path) {
    --hover-scale: 0;
    --hover-offset-y: 0px;
    transform-box: fill-box;
    transform-origin: center;
    backface-visibility: hidden;
    will-change: transform, opacity, fill;
    fill: currentColor !important;
    transition:
      --hover-scale 0.75s cubic-bezier(0.22, 1, 0.36, 1),
      --hover-offset-y 0.75s cubic-bezier(0.22, 1, 0.36, 1),
      color 0.5s ease,
      fill 0.5s ease,
      filter 0.5s ease;
  }

  .hero-logo-svg :global(.anim-path.letter) {
    color: var(--letter-base-color, #4f4c4d);
    animation: letter-wave 5.2s ease-in-out infinite;
    animation-delay: calc(var(--stagger-delay) * var(--stagger-index, 0));
    animation-play-state: paused;
  }

  .hero-logo-variant[data-intro-done="true"] .hero-logo-svg :global(.anim-path.letter) {
    animation-play-state: running;
  }

  .hero-logo-svg :global(.logo-wrapper > g .anim-path) {
    transition-delay: calc(var(--stagger-delay) * var(--stagger-index, 0));
  }

  .logo-trigger-area:hover .hero-logo-svg :global(.anim-path.letter),
  .logo-trigger-area:focus-visible .hero-logo-svg :global(.anim-path.letter) {
    animation-play-state: paused;
    --hover-scale: 0.15;
    --hover-offset-y: -5px;
    filter: drop-shadow(0 0 10px rgba(77, 192, 131, 0.6));
  }

  .logo-trigger-area:hover .hero-logo-svg :global(.dynamic-logo),
  .logo-trigger-area:focus-visible .hero-logo-svg :global(.dynamic-logo) {
    filter: drop-shadow(0 15px 35px rgba(77, 192, 131, 0.15));
  }

  .hero-logo-svg :global(.anim-path.green-dot) {
    color: #4dc083;
    transition-duration: 1.2s;
    transform-origin: center;
    transform-box: fill-box;
    transition: transform 1.2s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    animation: pulse-glow-flip 4s infinite linear;
    animation-play-state: paused;
  }

  .hero-logo-variant[data-intro-done="true"] .hero-logo-svg :global(.anim-path.green-dot) {
    animation-play-state: running;
  }

  .logo-trigger-area:hover .hero-logo-svg :global(.anim-path.green-dot),
  .logo-trigger-area:focus-visible .hero-logo-svg :global(.anim-path.green-dot) {
    animation-play-state: paused;
    --hover-scale: 0.15;
    --hover-offset-y: -5px;
    filter: drop-shadow(0 0 20px rgba(255, 255, 255, 0.9));
  }

  .logo-trigger-area:not(:hover):not(:focus-visible) .hero-logo-svg :global(.anim-path) {
    transition-delay: 0s !important;
  }

  @keyframes float {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-10px);
    }
  }

  @keyframes pulse-glow-flip {
    0%,
    15% {
      filter: drop-shadow(0 0 2px rgba(77, 192, 131, 0.5));
      transform: translateY(var(--hover-offset-y)) scale(calc(1 + var(--hover-scale))) rotateX(0deg);
    }
    25% {
      filter: drop-shadow(0 0 15px rgba(77, 192, 131, 1));
      transform: translateY(var(--hover-offset-y)) scale(calc(1 + var(--hover-scale))) rotateX(0deg);
    }
    35% {
      filter: drop-shadow(0 0 15px rgba(77, 192, 131, 1));
      transform: translateY(var(--hover-offset-y)) scale(calc(1 + var(--hover-scale))) rotateX(360deg);
    }
    50%,
    100% {
      filter: drop-shadow(0 0 2px rgba(77, 192, 131, 0.5));
      transform: translateY(var(--hover-offset-y)) scale(calc(1 + var(--hover-scale))) rotateX(360deg);
    }
  }

  @keyframes letter-wave {
    0%,
    100% {
      transform: translateY(calc(0px + var(--hover-offset-y))) scale(calc(1 + var(--hover-scale)));
      filter: drop-shadow(0 0 0 rgba(77, 192, 131, 0));
    }
    35% {
      transform: translateY(calc(-1.6px + var(--hover-offset-y))) scale(calc(1.015 + var(--hover-scale)));
      filter: drop-shadow(0 0 4px rgba(77, 192, 131, 0.16));
    }
    60% {
      transform: translateY(calc(-2.4px + var(--hover-offset-y))) scale(calc(1.022 + var(--hover-scale)));
      filter: drop-shadow(0 0 6px rgba(77, 192, 131, 0.2));
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-logo-svg :global(.dynamic-logo),
    .hero-logo-svg :global(.anim-path.green-dot) {
      animation: none !important;
    }

    .hero-logo-svg :global(.anim-path) {
      transition-duration: 0.01ms !important;
      transition-delay: 0s !important;
    }

    .hero-logo-svg :global(.anim-path.letter) {
      animation: none !important;
    }
  }
</style>

<script>
  import { gsap } from "gsap";

  function clearIntroTransforms(nodes: SVGGraphicsElement[]) {
    nodes.forEach((node) => {
      node.style.removeProperty("transform");
      node.style.removeProperty("transform-origin");
      node.style.removeProperty("fill");
      node.removeAttribute("transform");
      node.removeAttribute("data-svg-origin");
    });
  }

  function prepareLogoStructure(svg: SVGSVGElement) {
    svg.classList.add("dynamic-logo");

    const firstGroup = svg.querySelector<SVGGElement>(":scope > g");
    const logoWrapper = firstGroup ?? svg;
    if (logoWrapper instanceof SVGGElement) {
      logoWrapper.classList.add("logo-wrapper");
    }

    const directPaths = Array.from(logoWrapper.querySelectorAll(":scope > path"));
    directPaths.forEach((pathNode) => {
      const wrap = document.createElementNS("http://www.w3.org/2000/svg", "g");
      pathNode.parentNode?.insertBefore(wrap, pathNode);
      wrap.appendChild(pathNode);
    });

    const groups = Array.from(logoWrapper.querySelectorAll<SVGGElement>(":scope > g"));
    groups.forEach((groupNode, index) => {
      groupNode.style.setProperty("--stagger-index", String(index + 1));
    });

    const allPaths = Array.from(
      svg.querySelectorAll<SVGGraphicsElement>(
        "path, polygon, rect, circle, ellipse, line, polyline"
      )
    );

    return { logoWrapper, allPaths };
  }

  function initHeroLogoAnimation() {
    const logoBlocks = document.querySelectorAll<HTMLElement>("[data-hero-logo]");
    if (!logoBlocks.length) return;

    logoBlocks.forEach((logoBlock) => {
      if (logoBlock.dataset.gsapReady === "true") return;

      const svg = logoBlock.querySelector<SVGSVGElement>("svg");
      if (!svg) return;

      const { allPaths: paths } = prepareLogoStructure(svg);
      if (!paths.length) return;

      const mark = paths.find((node) => {
        const styleAttr = node.getAttribute("style") ?? "";
        const fillAttr = (node.getAttribute("fill") ?? "").toLowerCase();
        return /fill:\s*#4dc083/i.test(styleAttr) || fillAttr === "#4dc083";
      });
      if (!mark) return;

      const letters = paths
        .filter((node) => node !== mark)
        .sort((a, b) => a.getBBox().x - b.getBBox().x);

      const getFillColor = (node: SVGGraphicsElement) => {
        const styleAttr = node.getAttribute("style") ?? "";
        const styleMatch = styleAttr.match(/fill:\s*([^;]+)/i);
        const fillAttr = node.getAttribute("fill");
        return (styleMatch?.[1] ?? fillAttr ?? "#4f4c4d").trim().toLowerCase();
      };

      const baseLetterFill = getFillColor(letters[0] ?? mark);
      logoBlock.style.setProperty("--letter-base-color", baseLetterFill);

      mark.classList.add("anim-path", "green-dot");

      letters.forEach((node, index) => {
        node.classList.add("anim-path", "letter", `letter-${index + 1}`);
      });

      logoBlock.dataset.gsapReady = "true";
      const media = window.matchMedia("(prefers-reduced-motion: reduce)");

      const intro = () => {
        gsap.killTweensOf([mark, ...letters]);

        gsap.set(mark, {
          opacity: 0,
          y: 8,
          x: 0,
          scaleX: 0,
          rotation: 0,
          fill: "#4dc083",
          transformOrigin: "left center",
          transformBox: "fill-box",
          force3D: true,
        });

        gsap.set(letters, {
          opacity: 0,
          y: 8,
          skewX: 2,
          fill: baseLetterFill,
          transformOrigin: "50% 50%",
          transformBox: "fill-box",
          force3D: true,
        });

        if (media.matches) {
          gsap.to([mark, ...letters], {
            opacity: 1,
            y: 0,
            skewX: 0,
            scaleX: 1,
            duration: 0.2,
            ease: "none",
            stagger: 0.01,
          });
          clearIntroTransforms([mark, ...letters]);
          logoBlock.dataset.introDone = "true";
          return;
        }

        const timeline = gsap.timeline({ defaults: { ease: "power3.out" } });

        timeline.to(mark, {
          opacity: 1,
          y: 0,
          scaleX: 1,
          duration: 0.42,
          ease: "power2.out",
        });

        timeline.to(
          letters,
          {
            opacity: 1,
            y: 0,
            skewX: 0,
            duration: 0.46,
            stagger: 0.045,
          },
          0.24
        );

        timeline.call(() => {
          clearIntroTransforms([mark, ...letters]);
          logoBlock.dataset.introDone = "true";
        }, [], ">+0.45");
      };
      media.addEventListener("change", intro);

      intro();
    });
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initHeroLogoAnimation, {
      once: true,
    });
  } else {
    initHeroLogoAnimation();
  }

  document.addEventListener("astro:page-load", initHeroLogoAnimation);
</script>
