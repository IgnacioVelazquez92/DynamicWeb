---
export interface ContactOption {
  area: string;
  phoneLabel: string;
  whatsappHref: string;
}

export interface BranchGroup {
  branch: string;
  options: ContactOption[];
}

export interface Props {
  className?: string;
  buttonText?: string;
  modalTitle?: string;
  modalSubtitle?: string;
  branches?: BranchGroup[];
}

const {
  className = "",
  buttonText = "Contactenos",
  modalTitle = "Canales de comunicacion",
  modalSubtitle = "Selecciona una sucursal y luego el area para iniciar WhatsApp.",
  branches = [
    {
      branch: "Sucursal Cordoba",
      options: [
        {
          area: "Nutricion",
          phoneLabel: "+54 9 3512 67-0600",
          whatsappHref: "#",
        },
        {
          area: "Ostomia",
          phoneLabel: "+54 9 3512 67-0601",
          whatsappHref: "#",
        },
      ],
    },
    {
      branch: "Sucursal Tucuman",
      options: [
        {
          area: "Nutricion",
          phoneLabel: "+54 9 381 000-0000",
          whatsappHref: "#",
        },
        {
          area: "Ostomia",
          phoneLabel: "+54 9 381 000-0001",
          whatsappHref: "#",
        },
      ],
    },
  ],
} = Astro.props;

const testWhatsappNumber = "+54 9 3512 67-0600";
const testWhatsappHref =
  "https://wa.me/5493512670600?text=Hola%20Dynamic%20SA%2C%20quiero%20realizar%20una%20consulta%20comercial.";

const normalizedBranches = branches.map((group) => ({
  ...group,
  options: group.options.map((option) => ({
    ...option,
    phoneLabel: testWhatsappNumber,
    whatsappHref: testWhatsappHref,
  })),
}));
---

<div data-contact-modal-root>
  <button
    type="button"
    class={`group inline-flex items-center justify-center rounded-full border border-primary bg-primary px-6 py-3 font-semibold text-white shadow-lg shadow-primary/25 transition-all duration-300 hover:-translate-y-0.5 hover:bg-secondary hover:border-secondary hover:shadow-xl hover:shadow-secondary/30 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-secondary focus-visible:ring-offset-2 focus-visible:ring-offset-[rgb(var(--color-bg))] ${className}`}
    data-contact-open
  >
    <span class="relative z-10">{buttonText}</span>
  </button>

  <div
    class="fixed inset-0 z-[9999] hidden items-center justify-center p-4 sm:p-6"
    aria-hidden="true"
    data-contact-modal
  >
    <button
      class="absolute inset-0 bg-slate-950/55 backdrop-blur-sm transition-opacity duration-300"
      aria-label="Cerrar modal de contacto"
      data-contact-close
    ></button>

    <div
      class="relative w-full max-w-4xl overflow-hidden rounded-3xl border border-box-border bg-box-bg text-heading-2 shadow-2xl"
      role="dialog"
      aria-modal="true"
      aria-labelledby="contact-channels-title"
    >
      <div class="absolute inset-0 -z-10">
        <div class="absolute -left-20 top-0 h-52 w-52 rounded-full bg-primary/15 blur-3xl"></div>
        <div class="absolute -right-16 bottom-0 h-56 w-56 rounded-full bg-secondary/20 blur-3xl"></div>
      </div>

      <div class="border-b border-box-border px-6 pb-5 pt-6 sm:px-8">
        <button
          class="absolute right-4 top-4 grid h-9 w-9 place-items-center rounded-full border border-transparent text-heading-3 transition-all hover:border-box-border hover:bg-box-bg hover:text-heading-1 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-secondary"
          aria-label="Cerrar"
          data-contact-close
        >
          <span aria-hidden="true">×</span>
        </button>

        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-secondary">Canales de atencion</p>
        <h2 id="contact-channels-title" class="mt-2 text-2xl font-bold text-heading-1 sm:text-3xl">
          {modalTitle}
        </h2>
        <p class="mt-2 text-sm text-heading-3">
          {modalSubtitle}
        </p>
      </div>

      <div class="max-h-[78vh] overflow-y-auto overflow-x-hidden p-6 sm:p-8">
        <div class="grid grid-cols-1 gap-5 md:grid-cols-2">
        {
          normalizedBranches.map((group) => (
            <section class="min-w-0 rounded-2xl border border-box-border bg-box-bg/90 p-5 shadow-sm backdrop-blur-sm transition-colors hover:border-secondary/40">
              <h3 class="text-base font-semibold text-heading-1 sm:text-lg">{group.branch}</h3>
              <div class="mt-4 space-y-3">
                {
                  group.options.map((option) => (
                    <article class="min-w-0 rounded-xl border border-box-border bg-box-bg p-4 shadow-sm transition-all duration-300 hover:-translate-y-0.5 hover:border-secondary/60 hover:shadow-lg hover:shadow-secondary/10">
                      <p class="text-sm font-semibold text-heading-1 sm:text-base">{option.area}</p>
                      <p class="mt-1 text-xs text-heading-3">{option.phoneLabel}</p>
                      <a
                        href={option.whatsappHref}
                        target="_blank"
                        rel="noopener noreferrer"
                        aria-label={`Abrir WhatsApp para ${group.branch} - ${option.area}`}
                        class="mt-3 inline-flex w-full items-center justify-center gap-2 rounded-full border border-secondary bg-secondary/10 px-3 py-2 text-sm font-medium text-secondary transition-all duration-200 hover:-translate-y-0.5 hover:bg-secondary hover:text-white hover:shadow-lg hover:shadow-secondary/30 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-secondary focus-visible:ring-offset-2 focus-visible:ring-offset-box-bg"
                      >
                        <svg
                          xmlns="http://www.w3.org/2000/svg"
                          viewBox="0 0 24 24"
                          fill="currentColor"
                          class="h-4 w-4"
                          aria-hidden="true"
                        >
                          <path
                            d="M12 2a10 10 0 0 0-8.66 15l-1.1 4.02 4.12-1.08A10 10 0 1 0 12 2Zm0 18.3a8.24 8.24 0 0 1-4.2-1.15l-.3-.17-2.44.64.65-2.39-.2-.3A8.3 8.3 0 1 1 12 20.3Zm4.55-6.15c-.25-.13-1.46-.72-1.68-.8-.22-.08-.39-.12-.55.12s-.64.8-.78.96c-.14.16-.28.18-.53.06a6.77 6.77 0 0 1-1.98-1.22 7.44 7.44 0 0 1-1.37-1.7c-.14-.24-.01-.37.1-.5.1-.1.24-.27.36-.4.12-.14.16-.24.24-.4.08-.16.04-.3-.02-.42-.06-.13-.55-1.33-.75-1.82-.2-.48-.4-.42-.55-.43h-.46c-.16 0-.42.06-.64.3-.22.24-.84.82-.84 2s.86 2.32.98 2.48c.12.16 1.7 2.6 4.13 3.65.58.25 1.03.4 1.39.52.58.18 1.12.15 1.54.09.47-.07 1.46-.6 1.66-1.17.2-.58.2-1.08.14-1.18-.06-.1-.22-.16-.47-.29Z"
                          ></path>
                        </svg>
                        Ir a WhatsApp
                      </a>
                    </article>
                  ))
                }
              </div>
            </section>
          ))
        }
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  document.querySelectorAll("[data-contact-modal-root]").forEach((root) => {
    const openButton = root.querySelector("[data-contact-open]");
    const modal = root.querySelector("[data-contact-modal]");
    const closeButtons = root.querySelectorAll("[data-contact-close]");
    const closeButton = modal?.querySelector("[data-contact-close]");
    let lastFocusedElement: HTMLElement | null = null;

    if (!(openButton instanceof HTMLElement) || !(modal instanceof HTMLElement)) {
      return;
    }

    document.body.appendChild(modal);

    const openModal = () => {
      lastFocusedElement = document.activeElement instanceof HTMLElement ? document.activeElement : null;
      modal.classList.remove("hidden");
      modal.classList.add("flex");
      modal.setAttribute("aria-hidden", "false");
      document.body.classList.add("overflow-hidden");
      if (closeButton instanceof HTMLElement) {
        closeButton.focus();
      }
    };

    const closeModal = () => {
      modal.classList.add("hidden");
      modal.classList.remove("flex");
      modal.setAttribute("aria-hidden", "true");
      document.body.classList.remove("overflow-hidden");
      lastFocusedElement?.focus();
    };

    openButton.addEventListener("click", openModal);
    closeButtons.forEach((button) => {
      button.addEventListener("click", closeModal);
    });

    window.addEventListener("keydown", (event) => {
      if (event.key === "Escape" && modal.getAttribute("aria-hidden") === "false") {
        closeModal();
      }
    });
  });
</script>
