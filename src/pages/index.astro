---
import "../styles/global.css";
import Layout from "../layouts/Layout.astro";
import Hero from "../components/sections/Hero.astro";
import Services from "../components/sections/Services.astro";
import AboutUs from "../components/sections/AboutUs.astro";
import CTA from "../components/sections/CTA.astro";
import Contact from "../components/sections/Contact.astro";

const baseUrl = import.meta.env.BASE_URL;
const siteOrigin = "https://dynamicsa.com.ar";
const logoUrl = new URL(`${baseUrl}logos/Dynamic.png`, siteOrigin).toString();

const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "Pharmacy",
  name: "Dynamic SA",
  url: new URL(baseUrl, siteOrigin).toString(),
  logo: logoUrl,
  image: logoUrl,
  description:
    "Drogueria y distribuidora farmaceutica. Comercializacion y distribucion de medicamentos e insumos medicos en Cordoba y Tucuman.",
  email: "comercial@dynamicsa.com.ar",
  telephone: "+54 9 3512 67-0600",
  areaServed: ["Cordoba", "Tucuman", "Argentina"],
  address: [
    {
      "@type": "PostalAddress",
      streetAddress: "Santiago del Estero 1616",
      addressLocality: "San Miguel de Tucuman",
      addressRegion: "Tucuman",
      addressCountry: "AR",
    },
    {
      "@type": "PostalAddress",
      streetAddress: "Spilimbergo 6392",
      addressLocality: "Cordoba",
      addressRegion: "Cordoba",
      addressCountry: "AR",
    },
  ],
};
---

<Layout
  title="Drogueria y Distribucion Farmaceutica en Cordoba y Tucuman"
  description="Dynamic SA es una drogueria y distribuidora farmaceutica en Cordoba y Tucuman. Abastecemos medicamentos e insumos medicos con rapidez, seguridad y trazabilidad para farmacias y centros de salud."
  keywords="drogueria en cordoba, drogueria en tucuman, distribuidora farmaceutica, medicamentos por mayor, insumos medicos, dynamic sa"
  structuredData={localBusinessSchema}
>
  <main class="flex flex-col gap-y-20 md:gap-y-32 overflow-hidden">
    <Hero />
    <Services />
    <AboutUs />
    <CTA />
    <Contact />
  </main>
</Layout>
